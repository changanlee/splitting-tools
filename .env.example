# Copy to .env and fill real values. .env* is gitignored (this template is
# the only env file in VCS). Secrets NEVER committed.

# --- Database (single Postgres: app tables + pg-boss + cost/rate) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/splitting

# --- Vision LLM via OpenRouter (the only external LLM dependency; used
#     ONLY through src/lib/llm/visionAdapter). 2026-05-20 migrated from
#     @anthropic-ai/sdk direct → OpenRouter OpenAI-compat; underlying
#     model is still Anthropic Sonnet 4.6 / Haiku 4.5. ---
OPENROUTER_API_KEY=
# Optional — sent as HTTP-Referer / X-Title for OpenRouter app ranking.
# In production set OPENROUTER_SITE_URL to https://<your domain>.
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=

# --- Production deploy (docker-compose.prod.yml + Caddy — see DEPLOY.md) ---
# Public domain Caddy serves + auto-obtains an HTTPS certificate for.
SPLIT_DOMAIN=
# Host port bindings. In production bind web + db to 127.0.0.1 so only
# Caddy (80/443) faces the public internet:
#   WEB_PORT=127.0.0.1:3010
#   DB_PORT=127.0.0.1:55470
# Locally a plain port is fine (WEB_PORT=3010).
WEB_PORT=3000
DB_PORT=5432

# --- IP-key HMAC secret (Story 1.7 review P3 — without this set, IP
#     hashing falls back to plain SHA-256 which is enumerable for
#     IPv4. Set in any prod / staging deploy.) ---
IP_HASH_SECRET=

# --- Admin secret (Epic 7 — gates /admin where access codes are
#     managed). Unset = /admin is unreachable (fail-closed). Set a long
#     random value in any deploy: openssl rand -hex 24 ---
ADMIN_SECRET=

# --- Sentry (optional; unset = graceful no-op, app does not crash) ---
SENTRY_DSN=

# --- Share-link id entropy (Story 3.1 — generateLinkId reads 16 bytes
#     from crypto.randomBytes regardless; this var is informational). ---
LINK_ID_BYTES=16

# --- Parse-endpoint budget / rate gate (consumed in Story 1.7;
#     FR46 / NFR-S7 / NFR-L5 — values here are scaffold placeholders) ---
PARSE_BUDGET_MAX_USD_PER_DAY=5
PARSE_BUDGET_MAX_CALLS_PER_SESSION=10
PARSE_BUDGET_WINDOW_SECONDS=86400
