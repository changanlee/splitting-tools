# Copy to .env and fill real values. .env* is gitignored (this template is
# the only env file in VCS). Secrets NEVER committed.

# --- Database (single Postgres: app tables + pg-boss + cost/rate) ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/splitting

# --- Claude vision LLM (the only external dependency; used ONLY via
#     src/lib/llm/visionAdapter, filled in Story 1.4) ---
ANTHROPIC_API_KEY=

# --- Sentry (optional; unset = graceful no-op, app does not crash) ---
SENTRY_DSN=

# --- Share-link id entropy (link generation logic lands in Story 3.1) ---
LINK_ID_BYTES=16

# --- Parse-endpoint budget / rate gate (consumed in Story 1.7;
#     FR46 / NFR-S7 / NFR-L5 — values here are scaffold placeholders) ---
PARSE_BUDGET_MAX_USD_PER_DAY=5
PARSE_BUDGET_MAX_CALLS_PER_SESSION=10
PARSE_BUDGET_WINDOW_SECONDS=86400
